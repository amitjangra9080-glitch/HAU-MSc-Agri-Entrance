# Server-only Firebase Admin credential. Preferred setup:
# Base64-encode the complete downloaded service-account JSON file and store it
# only in Vercel as FIREBASE_SERVICE_ACCOUNT_BASE64.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Public Firebase Web API key used server-side only to verify email/password
# credentials and request password-reset emails through Identity Toolkit.
FIREBASE_WEB_API_KEY=

# Private server-only HMAC secret used to hash rate-limit subjects such as IP
# addresses and admission numbers before storing counters. Use 32+ characters.
AUTH_RATE_LIMIT_SECRET=

# Registration writes remain disabled unless this is explicitly set to true.
REGISTRATION_WRITE_ENABLED=false

# Legacy fallback formats supported for migration only:
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
